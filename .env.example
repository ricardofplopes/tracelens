# TraceLens
# ==========
# Core
POSTGRES_USER=tracelens
POSTGRES_PASSWORD=tracelens_secret
POSTGRES_DB=tracelens
DATABASE_URL=postgresql+asyncpg://tracelens:tracelens_secret@postgres:5432/tracelens

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Ollama
OLLAMA_HOST=http://ollama:11434
OLLAMA_VISION_MODEL=llava
OLLAMA_TEXT_MODEL=llama3.2

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Provider config (optional)
SAUCENAO_API_KEY=
GOOGLE_LENS_ENABLED=false
YANDEX_ENABLED=false
IQDB_ENABLED=true
SAUCENAO_ENABLED=true
WIKIMEDIA_ENABLED=true
WEB_SEARCH_ENABLED=true

# Playwright
PLAYWRIGHT_TIMEOUT=30000
